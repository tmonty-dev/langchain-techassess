# LLM Provider Configuration (choose one or multiple)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///data/assessments.db

# Application Settings
LOG_LEVEL=INFO
LOG_FILE=logs/assessment.log
SESSION_TIMEOUT_HOURS=24

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Security (generate secure random strings in production)
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# LangChain Tracing (optional, for debugging)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langchain_api_key